{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start backend dev server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"start:dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Start backend dev server 3011",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$env:PORT=3011; npm run start:dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Install soap package",
			"type": "shell",
			"command": "npm",
			"args": [
				"install",
				"soap"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}